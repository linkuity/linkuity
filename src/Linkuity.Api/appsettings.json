{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Linkuity": {
    "RuntimeMode": "Local"
  },
  "ArtifactStorage": {
    "RootPath": ".linkuity/jobs"
  },
  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "linkuity-jobs"
  },
  "AzureServiceBus": {
    "ConnectionString": "",
    "SmallJobQueueName": "linkuity-jobs-small",
    "LargeJobQueueName": "linkuity-jobs-large",
    "LargeJobThreshold": 10000,
    "PostProcessingQueueName": "linkuity-post-processing"
  }
}
