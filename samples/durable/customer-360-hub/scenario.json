{
  "name": "customer-360-hub",
  "description": "Person MDM hub seeded from a prior standalone run, then evolved over three incremental ingests.",
  "steps": [
    { "command": "project create",
      "args": { "name": "Customer 360", "content-type": "person", "merge-policy": "data/merge-policy.json" },
      "capture": "projectId" },
    { "command": "source create",
      "args": { "project-id": "{projectId}", "name": "Import" },
      "capture": "sourceId" },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "2" },
      "capture": "seedBatchId" },
    { "command": "persist-batch",
      "args": { "artifact-root": "data/artifacts", "job-id": "00000000-0000-0000-0000-000000000b01",
                "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{seedBatchId}" } },

    { "command": "golden list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "mkt-011" },
                              "expect": { "version": "1", "email": "carol.chen+m@example.com" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "mktBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{mktBatchId}",
                "input": "data/marketing-batch.csv", "profiles": "customer.profile.json" },
      "assert": { "stdout": { "Records added": "1", "Auto matches": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "mkt-013" },
                              "expect": { "record_count": "3" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "crmBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{crmBatchId}",
                "input": "data/crm-upgrade.csv", "profiles": "customer.profile.json" },
      "assert": { "stdout": { "Auto matches": "1", "Golden versions created": "1" } } },
    { "command": "golden list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "crm-010" },
                              "expect": { "version": "2", "email": "carol.chen@example.com" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "webBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{webBatchId}",
                "input": "data/web-borderline.csv", "profiles": "customer.profile.json" },
      "assert": { "stdout": { "Review tasks": "1" } } },
    { "command": "review list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "reason": "review_threshold" },
                              "expect": { "status": "open" } } ] } }
  ]
}
