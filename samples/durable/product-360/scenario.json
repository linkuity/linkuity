{
  "name": "product-360",
  "description": "Product MDM resolved end to end by a configuration-only matching profile using profile-declared FieldRole.Identifier fields (SKU and GTIN). Showcases SKU/GTIN as strong identifiers and same-name/different-identifier disambiguation.",
  "steps": [
    { "command": "project create",
      "args": { "name": "Product 360", "content-type": "product" },
      "capture": "projectId" },
    { "command": "source create",
      "args": { "project-id": "{projectId}", "name": "Import" },
      "capture": "sourceId" },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "3" },
      "capture": "seedBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{seedBatchId}",
                "input": "data/seed.csv", "profiles": "product.profile.json" },
      "assert": { "stdout": { "Records added": "3", "Auto matches": "0", "Singleton clusters": "3" } } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "skuBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{skuBatchId}",
                "input": "data/same-sku.csv", "profiles": "product.profile.json" },
      "assert": { "stdout": { "Auto matches": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "shop-010" },
                              "expect": { "record_count": "2" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "gtinBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{gtinBatchId}",
                "input": "data/gtin-match.csv", "profiles": "product.profile.json" },
      "assert": { "stdout": { "Auto matches": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "supp-020" },
                              "expect": { "record_count": "3" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "nameBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{nameBatchId}",
                "input": "data/name-collision.csv", "profiles": "product.profile.json" },
      "assert": { "stdout": { "Records added": "1", "Auto matches": "0", "Review tasks": "0", "Singleton clusters": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "web-030" },
                              "expect": { "record_count": "1" } } ] } }
  ]
}
