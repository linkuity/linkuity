{
  "name": "organization-360",
  "description": "Organization MDM resolved end to end by a configuration-only matching profile (no engine code changes). Showcases domain/email as strong identifiers and same-name/different-domain disambiguation.",
  "steps": [
    { "command": "project create",
      "args": { "name": "Organization 360", "content-type": "organization", "merge-policy": "data/merge-policy.json" },
      "capture": "projectId" },
    { "command": "source create",
      "args": { "project-id": "{projectId}", "name": "Import" },
      "capture": "sourceId" },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "3" },
      "capture": "seedBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{seedBatchId}",
                "input": "data/seed.csv" },
      "assert": { "stdout": { "Records added": "3", "Auto matches": "0", "Singleton clusters": "3" } } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "webBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{webBatchId}",
                "input": "data/web-acme.csv" },
      "assert": { "stdout": { "Records added": "1", "Auto matches": "0", "Review tasks": "0", "Singleton clusters": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "web-020" },
                              "expect": { "record_count": "1" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "mktBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{mktBatchId}",
                "input": "data/marketing-acme.csv" },
      "assert": { "stdout": { "Auto matches": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "mkt-010" },
                              "expect": { "record_count": "2" } } ] } },
    { "command": "golden list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "mkt-010" },
                              "expect": { "domain_name": "acme.com" } } ] } },

    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "finBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{finBatchId}",
                "input": "data/finance-globex.csv" },
      "assert": { "stdout": { "Auto matches": "1" } } },
    { "command": "cluster list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "fin-030" },
                              "expect": { "record_count": "2" } } ] } },

    { "command": "project create",
      "args": { "name": "Organization Override Demo", "content-type": "organization" },
      "capture": "overrideProjectId" },
    { "command": "source create",
      "args": { "project-id": "{overrideProjectId}", "name": "Import" },
      "capture": "overrideSourceId" },
    { "command": "batch create",
      "args": { "project-id": "{overrideProjectId}", "source-id": "{overrideSourceId}", "record-count": "2" },
      "capture": "overrideBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{overrideProjectId}", "source-id": "{overrideSourceId}", "batch-id": "{overrideBatchId}",
                "input": "data/override-acme.csv", "profiles": "data/organization-override.profile.json" },
      "assert": { "stdout": { "Records added": "2", "Auto matches": "0", "Review tasks": "1", "Singleton clusters": "2" } } }
  ]
}
