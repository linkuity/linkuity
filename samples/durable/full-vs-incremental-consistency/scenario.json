{
  "name": "full-vs-incremental-consistency",
  "description": "The same two records via full import (A) vs seed+incremental (B) yield the same golden email.",
  "steps": [
    { "command": "project create",
      "args": { "name": "Consistency A", "content-type": "person", "merge-policy": "data/merge-policy.json" },
      "capture": "projectA" },
    { "command": "source create",
      "args": { "project-id": "{projectA}", "name": "Import" },
      "capture": "sourceA" },
    { "command": "batch create",
      "args": { "project-id": "{projectA}", "source-id": "{sourceA}", "record-count": "2" },
      "capture": "batchA" },
    { "command": "persist-batch",
      "args": { "artifact-root": "data/artifacts", "job-id": "00000000-0000-0000-0000-000000000901",
                "project-id": "{projectA}", "source-id": "{sourceA}", "batch-id": "{batchA}" } },
    { "command": "golden list",
      "args": { "project-id": "{projectA}" },
      "assert": { "rows": [ { "where": { "member_ids~": "crm-400" },
                              "expect": { "email": "finn.fowler@example.com" } } ] } },

    { "command": "project create",
      "args": { "name": "Consistency B", "content-type": "person", "merge-policy": "data/merge-policy.json" },
      "capture": "projectB" },
    { "command": "source create",
      "args": { "project-id": "{projectB}", "name": "Import" },
      "capture": "sourceB" },
    { "command": "batch create",
      "args": { "project-id": "{projectB}", "source-id": "{sourceB}", "record-count": "1" },
      "capture": "seedB" },
    { "command": "persist-batch",
      "args": { "artifact-root": "data/artifacts", "job-id": "00000000-0000-0000-0000-000000000902",
                "project-id": "{projectB}", "source-id": "{sourceB}", "batch-id": "{seedB}" } },
    { "command": "batch create",
      "args": { "project-id": "{projectB}", "source-id": "{sourceB}", "record-count": "1" },
      "capture": "incB" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectB}", "source-id": "{sourceB}", "batch-id": "{incB}",
                "input": "data/incremental.csv" },
      "assert": { "stdout": { "Auto matches": "1" } } },
    { "command": "golden list",
      "args": { "project-id": "{projectB}" },
      "assert": { "rows": [ { "where": { "member_ids~": "crm-400" },
                              "expect": { "email": "finn.fowler@example.com" } } ] } }
  ]
}
