{
  "name": "golden-versioning",
  "description": "A higher-priority CRM record flips the golden email and creates version 2.",
  "steps": [
    { "command": "project create",
      "args": { "name": "Versioning", "content-type": "person", "merge-policy": "data/merge-policy.json" },
      "capture": "projectId" },
    { "command": "source create",
      "args": { "project-id": "{projectId}", "name": "Import" },
      "capture": "sourceId" },
    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "seedBatchId" },
    { "command": "persist-batch",
      "args": { "artifact-root": "data/artifacts", "job-id": "00000000-0000-0000-0000-000000000701",
                "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{seedBatchId}" } },
    { "command": "golden list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "mkt-201" },
                              "expect": { "version": "1", "email": "dana.doe+m@example.com" } } ] } },
    { "command": "batch create",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "record-count": "1" },
      "capture": "crmBatchId" },
    { "command": "ingest-incremental",
      "args": { "project-id": "{projectId}", "source-id": "{sourceId}", "batch-id": "{crmBatchId}",
                "input": "data/crm-upgrade.csv" },
      "assert": { "stdout": { "Auto matches": "1", "Golden versions created": "1" } } },
    { "command": "golden list",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "member_ids~": "crm-200" },
                              "expect": { "version": "2", "email": "dana.doe@example.com" } } ] } },
    { "command": "golden history",
      "args": { "project-id": "{projectId}" },
      "assert": { "rows": [ { "where": { "version": "1" },
                              "expect": { "email": "dana.doe+m@example.com" } },
                            { "where": { "version": "2" },
                              "expect": { "email": "dana.doe@example.com" } } ] } }
  ]
}
